function module-sync()
{
    local PREFIX=$1
    local MODULE=$2
    local TARGET=$3
    local VARIANT=$4
    local WORK_DIR=$5
    local SRC_DIR=$6
    local BUILD_DIR=$7

    echo p:$PREFIX
    echo m:$MODULE
    echo v:$VARIANT
    echo t:$TARGET
    echo w:$WORK_DIR
    echo s:$SRC_DIR
    echo b:$BUILD_DIR

    #  let's sync into the meta module metavar2

    local module_info=()
    get-module-ref module_info metavar2
    local module=${module_info[0]}
    local variant=${module_info[1]}

    #  get target/variant build dir
    local TVDIR=""
    get-target-dir TVDIR $module $variant

    echo T:$TVDIR
}

declare -fx module-sync

