
function module-final-step()
{
    local PREFIX=$1
    local TARGET=$2
    local VARIANT=$3
    local MODULE=$4
    local DEPENDS_KIND=$5
    local IS_META=$6
    local IS_AGGREGATED=$7
    local IS_UP_TO_DATE=$8

    local TVDIR=""
    get-module-ref MREF metaagg
    get-target-dir TVDIR metaagg ${MREF[1]}

    echo R m:$MODULE v:$VARIANT d:$DEPENDS_KIND m:$IS_META a:$IS_AGGREGATED i:$IS_UP_TO_DATE
    echo Copy $PREFIX
    echo To $TVDIR/app
}
